{
  "name": "tally-remote-fetcher",
  "version": "2.0.0",
  "description": "Tally ERP Integration - Standalone Application",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "axios": "^1.6.7",
    "fast-xml-parser": "^4.3.4",
    "pino": "^8.18.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.4"
  },
  "pkg": {
    "scripts": [
      "server.js"
    ],
    "assets": [
      "public/**/*",
      "src/**/*",
      "config.js",
      "node_modules/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "compress": "Brotli"
  }
}