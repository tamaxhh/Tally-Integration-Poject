# ============================================================
# Tally Integration — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- Tally Connection ---
# Tally must be running and have "Enable ODBC Server" checked.
# The default port is 9000 but some installs use 9001.
TALLY_HOST=localhost
TALLY_PORT=9000
TALLY_TIMEOUT_MS=5000       # 5 seconds — Tally is usually fast locally
TALLY_MAX_RETRIES=2         # How many times to retry a failed request
TALLY_COMPANY_NAME=         # Leave blank to use the active company in Tally

# --- Redis (cache) ---
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300       # How long to cache Tally responses (5 min default)

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/tally_integration

# --- Security ---
# Comma-separated list of valid API keys for your consumers.
# In production, use a proper secret manager (AWS Secrets Manager, Vault, etc.)
API_KEYS=dev-key-1234,prod-key-5678

# --- Logging ---
LOG_LEVEL=info              # debug | info | warn | error

# --- Background Jobs ---
SYNC_LEDGERS_CRON=*/10 * * * *   # Every 10 minutes
SYNC_VOUCHERS_CRON=*/5 * * * *   # Every 5 minutes
